{
  "version": 2,
  "name": "fea-api-gateway",
  "rewrites": [
    { "source": "/openapi.yaml", "destination": "/docs/openapi.yaml" },
    { "source": "/docs", "destination": "/docs/index.html" },
    { "source": "/", "destination": "/docs/index.html" },
    { "source": "/api/jobs/:id/results", "destination": "/api/jobs/[id]/results.js" },
    { "source": "/api/jobs/:id/files/:filename", "destination": "/api/jobs/[id]/files/[filename].js" },
    { "source": "/api/jobs/:id", "destination": "/api/jobs/[id].js" },
    { "source": "/api/mesh/quality", "destination": "/api/mesh.js" }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "GET, POST, PUT, DELETE, OPTIONS" },
        { "key": "Access-Control-Allow-Headers", "value": "Content-Type, Authorization, X-Requested-With" },
        { "key": "Access-Control-Max-Age", "value": "86400" }
      ]
    },
    {
      "source": "/docs/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=3600" }
      ]
    }
  ],
  "regions": ["iad1"]
}
